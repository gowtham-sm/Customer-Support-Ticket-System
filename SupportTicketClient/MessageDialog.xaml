<Window x:Class="SupportTicketClient.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Alert" Height="Auto" Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" Topmost="True"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular" TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal" TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Border Background="{DynamicResource MaterialDesignPaper}" CornerRadius="12" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="8" Opacity="0.3" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent" MouseDown="DragWindow_MouseDown">
                <Button HorizontalAlignment="Right" Style="{StaticResource MaterialDesignFlatButton}" Width="40" Height="40" Padding="0" Click="BtnOk_Click" Foreground="{DynamicResource MaterialDesignBody}">
                    <materialDesign:PackIcon Kind="WindowClose" Width="20" Height="20"/>
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="30,0,30,30">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <materialDesign:PackIcon Kind="AlertCircleOutline" Width="32" Height="32" Foreground="{DynamicResource SecondaryHueMidBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="lblTitle" Text="Notice" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock x:Name="txtMessage" Text="An unexpected error occurred." TextWrapping="Wrap" FontSize="15" Margin="0,0,0,25" Opacity="0.8"/>

                <Button Content="OK" Style="{StaticResource MaterialDesignRaisedButton}" HorizontalAlignment="Right" Width="90" Click="BtnOk_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>